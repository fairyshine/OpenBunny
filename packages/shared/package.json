{
  "name": "@openbunny/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./services/*": {
      "types": "./dist/services/*.d.ts",
      "import": "./dist/services/*.js"
    },
    "./stores/*": {
      "types": "./dist/stores/*.d.ts",
      "import": "./dist/stores/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "import": "./dist/platform/index.js"
    },
    "./platform/node": {
      "types": "./dist/platform/node.d.ts",
      "import": "./dist/platform/node.js"
    },
    "./platform/detect": {
      "types": "./dist/platform/detect.d.ts",
      "import": "./dist/platform/detect.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./platform/*": {
      "types": "./dist/platform/*.d.ts",
      "import": "./dist/platform/*.js"
    },
    "./i18n/locales/*": {
      "types": "./dist/i18n/locales/*.d.ts",
      "import": "./dist/i18n/locales/*.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node ./scripts/run-node-tests.mjs",
    "build": "node ./scripts/build.mjs"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/mcp": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "ai": "catalog:",
    "clsx": "catalog:",
    "croner": "^10.0.1",
    "i18next": "catalog:",
    "i18next-browser-languagedetector": "catalog:",
    "idb": "catalog:",
    "react-i18next": "catalog:",
    "tailwind-merge": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/uuid": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
