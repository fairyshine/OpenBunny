{
  "name": "@openbunny/desktop",
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @openbunny/shared build && pnpm --filter @openbunny/ui-web build && tsc && vite build && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "package": "pnpm --filter @openbunny/shared build && pnpm --filter @openbunny/ui-web build && tsc && vite build && electron-builder --dir",
    "package:mac": "pnpm --filter @openbunny/shared build && pnpm --filter @openbunny/ui-web build && tsc && vite build && electron-builder --mac",
    "package:win": "pnpm --filter @openbunny/shared build && pnpm --filter @openbunny/ui-web build && tsc && vite build && electron-builder --win",
    "package:linux": "pnpm --filter @openbunny/shared build && pnpm --filter @openbunny/ui-web build && tsc && vite build && electron-builder --linux"
  },
  "dependencies": {
    "@openbunny/shared": "workspace:*",
    "@openbunny/ui-web": "workspace:*",
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/mcp": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "ai": "catalog:",
    "clsx": "catalog:",
    "croner": "^10.0.1",
    "i18next": "catalog:",
    "i18next-browser-languagedetector": "catalog:",
    "idb": "catalog:",
    "react-i18next": "catalog:",
    "tailwind-merge": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:",
    "@dnd-kit/core": "catalog:",
    "@dnd-kit/sortable": "catalog:",
    "@dnd-kit/utilities": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-scroll-area": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "class-variance-authority": "catalog:",
    "date-fns": "catalog:",
    "elkjs": "^0.11.1",
    "howler": "^2.2.4",
    "lucide-react": "catalog:",
    "react-day-picker": "catalog:",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "catalog:",
    "reactflow": "^11.11.4",
