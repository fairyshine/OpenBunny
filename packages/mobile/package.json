{
  "name": "@openbunny/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build:shared": "pnpm --filter @openbunny/shared build",
    "start": "pnpm build:shared && expo start",
    "android": "pnpm build:shared && expo start --android",
    "ios": "pnpm build:shared && expo start --ios",
    "web": "pnpm build:shared && expo start --web",
    "typecheck": "tsc --noEmit",
    "typecheck:contracts": "pnpm --filter @openbunny/shared build && tsc -p tsconfig.contract.json --noEmit",
    "start:runtime": "expo start"
  },
  "dependencies": {
    "@openbunny/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "catalog:",
    "@react-navigation/bottom-tabs": "catalog:",
    "@react-navigation/drawer": "catalog:",
    "@react-navigation/native": "catalog:",
    "@react-navigation/native-stack": "catalog:",
    "expo": "catalog:",
    "expo-av": "^16.0.8",
    "expo-clipboard": "catalog:",
    "expo-file-system": "catalog:",
    "expo-localization": "catalog:",
    "expo-sharing": "catalog:",
    "expo-sqlite": "catalog:",
    "expo-status-bar": "catalog:",
    "i18next": "catalog:",
    "react": "catalog:",
    "react-i18next": "catalog:",
    "react-native": "catalog:",
    "react-native-gesture-handler": "catalog:",
    "react-native-markdown-display": "catalog:",
    "react-native-paper": "catalog:",
    "react-native-reanimated": "catalog:",
    "react-native-safe-area-context": "catalog:",
    "react-native-screens": "catalog:",
    "react-native-vector-icons": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@types/react": "catalog:",
    "typescript": "catalog:"
  }
}
