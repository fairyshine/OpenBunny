{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@openbunny/shared": [
        "../shared/src/index.ts"
      ],
      "@openbunny/shared/*": [
        "../shared/src/*"
      ]
    },
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
