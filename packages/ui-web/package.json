{
  "name": "@openbunny/ui-web",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap.d.ts",
      "import": "./dist/bootstrap.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./platform/*": {
      "types": "./dist/platform/*.d.ts",
      "import": "./dist/platform/*.js"
    },
    "./styles": "./dist/index.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node ./scripts-build.mjs"
  },
  "peerDependencies": {
    "@openbunny/shared": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "dependencies": {
    "@dnd-kit/core": "catalog:",
    "@dnd-kit/sortable": "catalog:",
    "@dnd-kit/utilities": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-scroll-area": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "date-fns": "catalog:",
    "elkjs": "^0.11.1",
    "howler": "^2.2.4",
    "lucide-react": "catalog:",
    "react-day-picker": "catalog:",
    "react-i18next": "catalog:",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "catalog:",
    "reactflow": "^11.11.4",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "catalog:",
    "tailwindcss-animate": "catalog:",
    "use-sound": "^5.0.0",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/uuid": "catalog:",
    "autoprefixer": "catalog:",
    "postcss": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
