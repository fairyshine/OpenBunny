{
  "name": "openbunny",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @openbunny/web dev",
    "dev:desktop": "pnpm --filter @openbunny/desktop dev",
    "dev:tui": "pnpm --filter @openbunny/tui dev",
    "dev:mobile": "pnpm --filter @openbunny/mobile start",
    "cli": "pnpm --filter @openbunny/cli dev --",
    "build": "pnpm --filter @openbunny/web build",
    "build:desktop": "pnpm --filter @openbunny/desktop build",
    "build:cli": "pnpm --filter @openbunny/cli build",
    "build:tui": "pnpm --filter @openbunny/tui build",
    "package:desktop": "pnpm --filter @openbunny/desktop package",
    "package:mac": "pnpm --filter @openbunny/desktop package:mac",
    "package:win": "pnpm --filter @openbunny/desktop package:win",
    "package:linux": "pnpm --filter @openbunny/desktop package:linux",
    "preview": "pnpm --filter @openbunny/web preview",
    "mobile:ios": "pnpm --filter @openbunny/mobile ios",
    "mobile:android": "pnpm --filter @openbunny/mobile android",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "version:sync": "node scripts/sync-version.mjs",
    "version:set": "node scripts/sync-version.mjs",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "verify:packages": "node scripts/verify-package-contracts.mjs",
    "check:exports": "node scripts/check-package-exports.mjs",
    "check:app-runtime-deps": "node scripts/check-app-runtime-deps.mjs"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
