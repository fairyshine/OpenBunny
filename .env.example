# WebAgent 环境变量配置

# LLM API 配置
# 注意：在浏览器中使用 API Key 有安全风险，建议通过代理服务器或使用不记名的兼容 API
VITE_OPENAI_API_KEY=your_api_key_here

# API 基础 URL（可选）
# 如果使用代理则不需要设置，否则设置为兼容 OpenAI API 的服务
VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# 默认模型
VITE_DEFAULT_MODEL=gpt-4

# MCP 服务器配置（可选）
VITE_MCP_SERVER_URL=ws://localhost:3000

# CORS 代理 Worker URL（生产环境需要）
# 部署 Cloudflare Worker 后填入，也可在设置界面运行时配置
VITE_PROXY_WORKER_URL=https://openbunny-proxy.your-account.workers.dev
