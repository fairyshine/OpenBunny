{
  "name": "@openbunny/cli",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "openbunny": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "pnpm --filter @openbunny/shared build && tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@openbunny/shared": "workspace:*",
    "ai": "catalog:",
    "chalk": "catalog:",
    "commander": "catalog:",
    "node-fetch": "catalog:",
    "ora": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
